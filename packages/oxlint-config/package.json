{
  "name": "@zachsents/oxlint-config",
  "version": "0.3.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "devDependencies": {
    "@typescript/native": "npm:typescript@^7.0.2",
    "typescript": "^6.0.3",
    "zshy": "^0.7.3"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "oxlint": ">=1.74.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./eslint": {
      "types": "./dist/eslint.d.ts",
      "default": "./dist/eslint.js"
    }
  },
  "description": "Zach's shared Oxlint and ESLint configuration.",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "zshy",
    "check": "bun run --cwd ../.. build:lint-plugin && bun run typecheck && bun run build",
    "prepublishOnly": "bun run check"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "zshy": {
    "exports": {
      ".": "./index.ts",
      "./react": "./react.ts",
      "./eslint": "./eslint.ts"
    },
    "cjs": false
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zachsents/zachs-tools.git",
    "directory": "packages/oxlint-config"
  },
  "dependencies": {
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint-plugin-jsdoc": "^63.0.13",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-zachs-rules": "0.3.0"
  }
}
